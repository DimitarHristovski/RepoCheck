# JSON store (default: ./data/repocheck-store.json)
# REPOCHECK_STORE_PATH=

# LLM — OpenAI-compatible (either name works)
OPENAI_API_KEY=
# API_KEY=
# Optional custom base (Azure, proxies)
OPENAI_BASE_URL=

# Provider: openai | ollama | none (env overrides UI when not "none")
# Legacy alias: FILESENTINEL_MODEL_PROVIDER
REPOCHECK_MODEL_PROVIDER=none
REPOCHECK_LLM_MODEL=gpt-4o-mini

OLLAMA_BASE_URL=http://127.0.0.1:11434

# Isolated analysis directory for local paths and GitHub ZIP extracts (default: ./.repocheck-analysis)
# Legacy alias: FILESENTINEL_ANALYSIS_ROOT
# REPOCHECK_ANALYSIS_ROOT=

LOG_LEVEL=debug
