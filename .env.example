# JSON store (default: ./data/repocheck-store.json)
# REPOCHECK_STORE_PATH=

# LLM — OpenAI-compatible (either name works)
OPENAI_API_KEY=
# API_KEY=
# Optional custom base (Azure, proxies)
OPENAI_BASE_URL=

# Provider: openai | ollama | none (env overrides UI when not "none")
# Legacy alias: FILESENTINEL_MODEL_PROVIDER
REPOCHECK_MODEL_PROVIDER=none
REPOCHECK_LLM_MODEL=gpt-4o-mini

OLLAMA_BASE_URL=http://127.0.0.1:11434

# Isolated analysis directory for local paths and GitHub ZIP extracts (default: ./.repocheck-analysis)
# Legacy alias: FILESENTINEL_ANALYSIS_ROOT
# REPOCHECK_ANALYSIS_ROOT=

LOG_LEVEL=debug


# Always-on guardian (runs inside Next server process)
# Enable background polling + local folder watch
# REPOCHECK_GUARDIAN_ENABLED=true
# Public repos to poll (owner/repo, comma-separated)
# REPOCHECK_GUARDIAN_GITHUB_REPOS=vercel/next.js,nodejs/node
# Absolute directories to watch on this machine (comma-separated)
# REPOCHECK_GUARDIAN_LOCAL_WATCH_DIRS=/Users/you/Downloads,/Users/you/Desktop/Git-Projects
# GitHub poll interval in milliseconds (min 60000)
# REPOCHECK_GUARDIAN_POLL_MS=300000
# Alert threshold for guardian notifications/audit logs
# REPOCHECK_GUARDIAN_ALERT_MIN_SEVERITY=high
# GitHub token for private repository scans/guardian polling (optional)
# REPOCHECK_GITHUB_TOKEN=
